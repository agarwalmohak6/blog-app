# .env.example - Template for environment variables
# Copy this file to .env in backend/ and frontend/ and customize as needed.

# ========================================
# Backend Configuration (backend/.env)
# ========================================
# Inside docker, this override points to the 'db' container.
# For local run without docker, use localhost.
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/blogapp
SECRET_KEY=supersecretkey-change-in-production

# ========================================
# Frontend Configuration (frontend/.env)
# ========================================
VITE_API_URL=http://localhost:8000
